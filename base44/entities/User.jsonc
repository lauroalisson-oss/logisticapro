{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "company_id": {
      "type": "string",
      "title": "Empresa"
    },
    "is_driver": {
      "type": "boolean",
      "title": "\u00c9 Motorista",
      "default": false
    },
    "driver_pin": {
      "type": "string",
      "title": "PIN do Motorista"
    },
    "phone": {
      "type": "string",
      "title": "Telefone"
    },
    "cpf": {
      "type": "string",
      "title": "CPF"
    },
    "license_number": {
      "type": "string",
      "title": "N\u00famero CNH"
    },
    "license_category": {
      "type": "string",
      "title": "Categoria CNH"
    },
    "license_points": {
      "type": "number",
      "title": "Pontos na CNH"
    }
  }
}