{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "title": "Perfil",
      "enum": [
        "admin",
        "dispatcher",
        "driver"
      ],
      "default": "driver"
    },
    "phone": {
      "type": "string",
      "title": "Telefone"
    },
    "vehicle_id": {
      "type": "string",
      "title": "Ve\u00edculo Vinculado"
    },
    "is_active": {
      "type": "boolean",
      "title": "Ativo",
      "default": true
    }
  }
}